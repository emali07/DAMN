<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F0FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <ImageView
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:src="@drawable/bienvenida_gym"
            android:contentDescription="Imagen bienvenida"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenida a AppGYM"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#4B4353"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diseña tu entrenamiento paso a paso"
            android:textSize="17sp"
            android:textColor="#6B6272"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp" />



        <Button
            android:id="@+id/btnEntrar"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:text="Entrar"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6F52B5" />

    </LinearLayout>
</ScrollView>