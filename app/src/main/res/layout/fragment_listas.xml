<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progreso de rutina"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#4B4353" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Da seguimiento a tu entrenamiento y avanza ejercicio por ejercicio hasta completar la rutina."
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:textColor="#5A5161" />

        <TextView
            android:id="@+id/tvEjercicioActual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ejercicio actual: Calentamiento"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#4B4353"
            android:layout_marginBottom="12dp" />

        <ProgressBar
            android:id="@+id/progressBarRutina"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/tvProgreso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progreso actual: 0%"
            android:textColor="#4B4353"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnCompletarEjercicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Completar ejercicio"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvEstadoRutina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estado: rutina en progreso"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:textColor="#4B4353"
            android:background="#EEE8F2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnAtrasProgreso"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Atrás"
                android:textStyle="bold"
                android:minHeight="48dp"
                android:backgroundTint="#CDB4DB"
                android:textColor="#4B4353"/>

            <Button
                android:id="@+id/btnSiguienteProgreso"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Siguiente"
                android:textStyle="bold"
                android:minHeight="48dp"
                android:backgroundTint="#CDB4DB"
                android:textColor="#4B4353" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>