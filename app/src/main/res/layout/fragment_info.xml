<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resumen final"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#4B4353" />

        <ImageView
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:contentDescription="Resumen del usuario"
            android:src="@drawable/resumen_final" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¡Buen trabajo! Ya completaste el flujo principal de tu entrenamiento personalizado."
            android:textStyle="bold"
            android:textColor="#4B4353"
            android:gravity="center"
            android:padding="14dp"
            android:background="#E9DEF8"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvResumenFinal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aquí aparecerá el resumen final..."
            android:textColor="#4B4353"
            android:background="#EEE8F2"
            android:padding="16dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mensaje motivacional"
            android:textStyle="bold"
            android:textColor="#4B4353"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F0EAF7"
            android:padding="14dp"
            android:text="Cada entrenamiento te acerca a tu mejor versión. Lo importante no es la perfección, sino la constancia."
            android:textColor="#5A5161" />

        <Button
            android:id="@+id/btnVolverInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Volver al perfil"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#8A67C7"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>