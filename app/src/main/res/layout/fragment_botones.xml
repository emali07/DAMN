<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ejercicios recomendados"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#4B4353" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona una rutina para mostrar ejercicios recomendados según la parte del cuerpo."
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:textColor="#5A5161" />

        <Button
            android:id="@+id/btnPecho"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mostrar ejercicios de pecho" />

        <Button
            android:id="@+id/btnPierna"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mostrar ejercicios de pierna"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnEspalda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mostrar ejercicios de espalda"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnAbdomen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mostrar ejercicios de abdomen"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnGluteo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mostrar ejercicios de glúteo"
            android:layout_marginTop="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnAtrasEjercicios"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Atrás"
                android:minHeight="48dp"
                android:backgroundTint="#CDB4DB"
                android:textColor="#4B4353"
                />

            <Button
                android:id="@+id/btnSiguienteEjercicios"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Siguiente"
                android:textStyle="bold"
                android:minHeight="48dp"
                android:backgroundTint="#CDB4DB"
                android:textColor="#4B4353"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvRutinaActual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rutina seleccionada: ninguna"
            android:textStyle="bold"
            android:textColor="#4B4353"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <ListView
            android:id="@+id/listViewRutina"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:dividerHeight="8dp" />

    </LinearLayout>
</ScrollView>